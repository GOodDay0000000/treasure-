  "malachi": {"author":"말라기","period":"BC 430년경","writtenAt":"예루살렘","theme":"마지막 경고","keyVerses":["3:1","4:2"],"summary":"구약 마지막 선지서. 형식적 제사를 책망하고 오실 메시아의 선구자(세례 요한)를 예언.","chapters":4,"testament":"old","region":"prophets","originalLang":"hebrew","tags":["메시아","선구자","십일조","침묵기"]},
  "matthew": {"author":"마태 (레위)","period":"AD 60~70년경","writtenAt":"안디옥 추정","theme":"약속된 왕 메시아","keyVerses":["1:21","28:19-20"],"summary":"유대인을 대상으로 예수님이 구약에 예언된 메시아이심을 증거. 산상수훈과 대위임령.","chapters":28,"testament":"new","region":"galilee","originalLang":"greek","tags":["메시아","왕","산상수훈","대위임령"]},
  "mark": {"author":"마가 (요한 마가)","period":"AD 55~65년경","writtenAt":"로마","theme":"섬기는 종 메시아","keyVerses":["10:45"],"summary":"베드로의 증언을 바탕으로 쓴 가장 짧은 복음서. 즉시 행동하시는 종의 모습 강조.","chapters":16,"testament":"new","region":"galilee","originalLang":"greek","tags":["종","행동","베드로","고난"]},
  "luke": {"author":"누가 (의사)","period":"AD 60~62년경","writtenAt":"가이사랴","theme":"인자와 구원자","keyVerses":["19:10","1:37"],"summary":"이방인 의사 누가가 면밀히 조사하여 기록. 예수의 인성과 약자에 대한 긍휼 강조.","chapters":24,"testament":"new","region":"galilee","originalLang":"greek","tags":["인자","긍휼","이방인","기도"]},
  "john": {"author":"사도 요한","period":"AD 85~95년경","writtenAt":"에베소","theme":"하나님의 아들 예수","keyVerses":["3:16","14:6","20:31"],"summary":"7가지 표적과 7가지 '나는 ~이다' 말씀으로 예수의 신성을 증거. 가장 영적인 복음서.","chapters":21,"testament":"new","region":"galilee","originalLang":"greek","tags":["로고스","아들","생명","믿음"]},
  "acts": {"author":"누가","period":"AD 62년경","writtenAt":"로마","theme":"성령과 교회의 확장","keyVerses":["1:8","2:42"],"summary":"성령 강림으로 시작된 예루살렘 교회부터 바울의 로마 도착까지 복음이 땅끝으로 퍼져나감.","chapters":28,"testament":"new","region":"jerusalem_nt","originalLang":"greek","tags":["성령","교회","선교","바울"]},
  "romans": {"author":"사도 바울","period":"AD 57년경","writtenAt":"고린도","theme":"복음의 본질","keyVerses":["1:16-17","3:23-24","8:28","12:1-2"],"summary":"가장 체계적인 바울 서신. 칭의, 성화, 영화로 이어지는 구원의 복음을 전개.","chapters":16,"testament":"new","region":"rome","originalLang":"greek","tags":["칭의","믿음","성화","이신칭의"]},
  "1corinthians": {"author":"사도 바울","period":"AD 55년경","writtenAt":"에베소","theme":"교회의 문제 해결","keyVerses":["13:13","15:3-4"],"summary":"분쟁·음행·우상·성찬·부활 등 고린도 교회의 다양한 문제에 대한 바울의 답변.","chapters":16,"testament":"new","region":"corinth","originalLang":"greek","tags":["사랑장","은사","부활","성찬"]},
  "2corinthians": {"author":"사도 바울","period":"AD 55~56년경","writtenAt":"마게도냐","theme":"고난 속의 사역","keyVerses":["5:17","12:9"],"summary":"거짓 교사들에 대항하여 바울의 사도권을 변호하고, 연약함 속의 능력을 고백.","chapters":13,"testament":"new","region":"corinth","originalLang":"greek","tags":["새 피조물","고난","사도권","약함"]},
  "galatians": {"author":"사도 바울","period":"AD 48~55년경","writtenAt":"미상","theme":"율법에서 자유","keyVerses":["2:20","5:22-23"],"summary":"할례·율법으로 구원받으려는 거짓 복음을 단호히 배격하고, 믿음으로 말미암는 자유를 선언.","chapters":6,"testament":"new","region":"asia_minor","originalLang":"greek","tags":["자유","성령의 열매","율법","믿음"]},
  "ephesians": {"author":"사도 바울","period":"AD 60~62년경","writtenAt":"로마 옥중","theme":"그리스도 안의 연합","keyVerses":["2:8-9","6:10-12"],"summary":"그리스도 안에서 유대인과 이방인이 한 몸이 된 교회의 신비와 영적 전쟁.","chapters":6,"testament":"new","region":"asia_minor","originalLang":"greek","tags":["은혜","연합","전신갑주","교회"]},
  "philippians": {"author":"사도 바울","period":"AD 60~62년경","writtenAt":"로마 옥중","theme":"그리스도 안의 기쁨","keyVerses":["4:4","4:13","2:5-11"],"summary":"옥중에서도 넘치는 기쁨을 증거. 그리스도의 겸손(비하와 승귀) 찬가.","chapters":4,"testament":"new","region":"asia_minor","originalLang":"greek","tags":["기쁨","겸손","비하","평강"]},
  "colossians": {"author":"사도 바울","period":"AD 60~62년경","writtenAt":"로마 옥중","theme":"그리스도의 충만","keyVerses":["1:15-17","2:9-10"],"summary":"영지주의 이단에 맞서 그리스도의 신성과 교회의 머리 되심을 선언.","chapters":4,"testament":"new","region":"asia_minor","originalLang":"greek","tags":["머리","충만","이단","연합"]},
  "1thessalonians": {"author":"사도 바울","period":"AD 51년경","writtenAt":"고린도","theme":"재림 준비","keyVerses":["4:16-17","5:17"],"summary":"바울의 가장 초기 서신 중 하나. 그리스도의 재림에 대한 소망과 성도의 삶.","chapters":5,"testament":"new","region":"epistles","originalLang":"greek","tags":["재림","소망","기도","휴거"]},
  "2thessalonians": {"author":"사도 바울","period":"AD 51~52년경","writtenAt":"고린도","theme":"재림에 대한 바른 이해","keyVerses":["2:3","3:10"],"summary":"재림에 대한 오해를 바로잡고, 불법의 사람의 출현 이전 경고.","chapters":3,"testament":"new","region":"epistles","originalLang":"greek","tags":["재림","불법의 사람","인내","수고"]},
  "1timothy": {"author":"사도 바울","period":"AD 62~64년경","writtenAt":"마게도냐","theme":"교회 지도자의 지침","keyVerses":["3:16","6:12"],"summary":"목회 서신. 목사·장로·집사의 자격과 거짓 교사에 대한 경계.","chapters":6,"testament":"new","region":"rome","originalLang":"greek","tags":["목회","지도자","교리","경건"]},
  "2timothy": {"author":"사도 바울","period":"AD 66~67년경","writtenAt":"로마 옥중","theme":"바울의 고별 편지","keyVerses":["3:16-17","4:7-8"],"summary":"순교 직전 디모데에게 보낸 유언과 같은 서신. '나는 선한 싸움을 싸웠다.'","chapters":4,"testament":"new","region":"rome","originalLang":"greek","tags":["고별","성경 영감","순교","끝까지"]},
  "titus": {"author":"사도 바울","period":"AD 62~64년경","writtenAt":"니고볼리","theme":"그레데 교회의 질서","keyVerses":["2:11-12","3:5"],"summary":"그레데 섬에 남겨둔 디도에게 교회의 질서 확립과 장로 임명을 지시.","chapters":3,"testament":"new","region":"rome","originalLang":"greek","tags":["질서","장로","중생","선행"]},
  "philemon": {"author":"사도 바울","period":"AD 60~62년경","writtenAt":"로마 옥중","theme":"용서와 화해","keyVerses":["1:10-11"],"summary":"도망친 노예 오네시모를 위한 바울의 중보. 복음이 신분을 초월한 형제애를 만듦.","chapters":1,"testament":"new","region":"rome","originalLang":"greek","tags":["용서","화해","노예","중보"]},
  "hebrews": {"author":"미상 (바울·바나바·아볼로 추정)","period":"AD 64~68년경","writtenAt":"미상","theme":"예수의 대제사장 되심","keyVerses":["4:12","11:1","12:2"],"summary":"유대 그리스도인에게 구약 제사와 언약이 예수 안에서 어떻게 성취되는지 논증.","chapters":13,"testament":"new","region":"epistles","originalLang":"greek","tags":["대제사장","언약","믿음","멜기세덱"]},
  "james": {"author":"예수의 동생 야고보","period":"AD 45~50년경","writtenAt":"예루살렘","theme":"행함 있는 믿음","keyVerses":["1:22","2:17"],"summary":"가장 실천적인 서신. 믿음은 행함으로 증명되며 혀와 시험을 다스려야 함.","chapters":5,"testament":"new","region":"epistles","originalLang":"greek","tags":["행함","혀","시험","기도"]},
  "1peter": {"author":"사도 베드로","period":"AD 63~64년경","writtenAt":"바벨론(로마 추정)","theme":"고난 속의 소망","keyVerses":["1:3-4","5:7"],"summary":"네로 박해 시작 무렵, 흩어진 성도들에게 산 소망과 고난의 의미를 가르침.","chapters":5,"testament":"new","region":"epistles","originalLang":"greek","tags":["산 소망","고난","택하신 족속","겸손"]},
  "2peter": {"author":"사도 베드로","period":"AD 65~68년경","writtenAt":"로마","theme":"거짓 교사 경고","keyVerses":["1:20-21","3:9"],"summary":"순교 직전 쓴 서신. 거짓 교사들을 경계하고 주의 재림이 더딤은 오래 참으심임을 가르침.","chapters":3,"testament":"new","region":"epistles","originalLang":"greek","tags":["거짓 교사","재림","성경","성장"]},
  "1john": {"author":"사도 요한","period":"AD 85~95년경","writtenAt":"에베소","theme":"사랑과 진리","keyVerses":["1:9","4:8"],"summary":"영지주의에 맞서 예수의 성육신을 증거하고 '서로 사랑하라'를 반복 권면.","chapters":5,"testament":"new","region":"epistles","originalLang":"greek","tags":["사랑","빛","영지주의","교제"]},
  "2john": {"author":"사도 요한","period":"AD 85~95년경","writtenAt":"에베소","theme":"진리 안에서 사랑","keyVerses":["1:6"],"summary":"선택받은 부녀에게 보낸 편지. 진리와 사랑, 거짓 교사 경계.","chapters":1,"testament":"new","region":"epistles","originalLang":"greek","tags":["진리","사랑","거짓 교사","가르침"]},
  "3john": {"author":"사도 요한","period":"AD 85~95년경","writtenAt":"에베소","theme":"교회 환대","keyVerses":["1:4"],"summary":"가이오에게 보낸 짧은 편지. 순회 사역자들에 대한 환대와 디오드레베의 교만을 책망.","chapters":1,"testament":"new","region":"epistles","originalLang":"greek","tags":["환대","증거","디오드레베","선행"]},
  "jude": {"author":"예수의 동생 유다","period":"AD 65~80년경","writtenAt":"미상","theme":"믿음을 위하여 싸우라","keyVerses":["1:3","1:24-25"],"summary":"교회에 침투한 거짓 교사들을 경계하고 한 번 주신 믿음의 도를 위해 힘써 싸우라 권고.","chapters":1,"testament":"new","region":"epistles","originalLang":"greek","tags":["거짓 교사","믿음","타락한 천사","축복"]},
  "revelation": {"author":"사도 요한","period":"AD 95년경","writtenAt":"밧모섬","theme":"최후의 승리","keyVerses":["1:8","21:4","22:20"],"summary":"밧모섬 유배 중 받은 환상. 역사의 종말과 그리스도의 재림, 새 예루살렘의 영광.","chapters":22,"testament":"new","region":"patmos","originalLang":"greek","tags":["환상","재림","새 예루살렘","어린 양"]}
